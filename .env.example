# Google Sheets API
# 1. Crea una hoja en Google Sheets con columnas: n | hospital | nombre | edad | cedula | telefono | direccion | observaciones
# 2. Comparte la hoja como "Cualquier persona con el enlace puede ver"
# 3. Activa la Sheets API en Google Cloud Console y crea una API Key
# 4. Copia el ID de la URL de tu hoja: docs.google.com/spreadsheets/d/{SHEET_ID}/edit

GOOGLE_SHEETS_ID=tu_sheet_id_aqui
GOOGLE_SHEETS_API_KEY=tu_api_key_aqui
GOOGLE_SHEETS_RANGE=Pacientes!A:H
