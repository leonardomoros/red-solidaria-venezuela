        <div class="card-addr"><strong>Av. Francisco de Miranda, Chacao</strong><span>Miranda</span></div>
        <div class="card-addr mt-3">🕐 7:00 AM – 8:00 PM</div>
        <a href="https://maps.google.com/?q=Alcaldia+Chacao+Miranda" target="_blank" class="card-link">📍 Ver en mapa →</a>
      </div>

      <div class="card" data-state="aragua">
        <span class="c-tag tag-green">✅ Activo · Aragua</span>
        <h3>Cruz Roja — Maracay</h3>
        <div class="card-meta">Alimentos, medicamentos, agua potable</div>
        <div class="card-addr"><strong>Av. Bolívar, Maracay</strong><span>Aragua</span></div>
        <div class="card-addr mt-3">🕐 8:00 AM – 5:00 PM</div>
