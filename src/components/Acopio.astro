<div id="donaciones"></div>
<section id="acopio">
  <div class="container">
    <div class="s-eye">📦 Función 03</div>
    <h2 class="s-title">Centros de acopio</h2>
    <p class="s-sub">Puntos verificados donde puedes llevar donaciones. Filtra por estado.</p>

    <div class="tabs" id="acopio-tabs">
      <button class="tab-btn active" onclick="filterAcopio('todos',this)">Todos</button>
      <button class="tab-btn" onclick="filterAcopio('caracas',this)">Caracas</button>
      <button class="tab-btn" onclick="filterAcopio('vargas',this)">La Guaira</button>
      <button class="tab-btn" onclick="filterAcopio('miranda',this)">Miranda</button>
      <button class="tab-btn" onclick="filterAcopio('aragua',this)">Aragua</button>
      <button class="tab-btn" onclick="filterAcopio('carabobo',this)">Carabobo</button>
    </div>

    <div class="grid-2" id="acopio-grid">
      <div class="card" data-state="caracas">
        <span class="c-tag tag-green">✅ Activo · Caracas</span>
        <h3>Cruz Roja — Sede Principal</h3>
        <div class="card-meta">Alimentos, medicamentos, ropa, agua</div>
        <div class="card-addr"><strong>Av. Andrés Bello, La Candelaria</strong><span>Caracas</span></div>
        <div class="card-addr mt-3">🕐 Lun–Dom · 8:00 AM – 6:00 PM</div>
        <a href="https://maps.google.com/?q=Cruz+Roja+Venezolana+Caracas" target="_blank" class="card-link">📍 Ver en mapa →</a>
      </div>

      <div class="card" data-state="caracas">
        <span class="c-tag tag-green">✅ Activo · Caracas</span>
        <h3>Protección Civil — Plaza Venezuela</h3>
