<script is:inline>
function filterAcopio(state, btn) {
  document.querySelectorAll('#acopio-tabs .tab-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('#acopio-grid .card').forEach(c => {
    const ds = c.dataset.state;
    c.classList.toggle('hidden', state !== 'todos' && ds !== state && ds !== 'todos');
  });
}
</script>
