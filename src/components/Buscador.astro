---
const sheetsKey = import.meta.env.PUBLIC_SHEETS_KEY ?? '';
---
<section id="hospitales" data-sk={sheetsKey}>
  <div class="container">
    <div class="s-eye">🏥 Función 01 · La más importante</div>
    <div class="flex-between">
      <div>
        <h2 class="s-title">Personas en centros de salud</h2>
      </div>
      <div id="pacientes-stats-hero" class="stats-hero-wrap"></div>
    </div>
    <p class="s-sub" id="pacientes-stats" style="display:none">Cargando datos actualizados...</p>

    <div class="cruce-box">
      <h3>¿Buscas a un familiar? Ingresa su nombre o cédula</h3>
      <div class="cruce-form">
        <label for="cruce-nombre" class="sr-only">Nombre y apellido</label>
        <input type="text" class="cruce-input" id="cruce-nombre"
          placeholder="Nombre y apellido..."
          autocomplete="off" autocorrect="off" spellcheck="false"/>
        <label for="cruce-cedula" class="sr-only">Número de cédula</label>
        <input type="text" class="cruce-input" id="cruce-cedula"
          placeholder="Número de cédula..."
          autocomplete="off"/>
        <button class="btn-amber" onclick="buscarFamiliar()">Buscar familiar</button>
      </div>
      <div class="cruce-results" id="cruce-results" style="display:none" aria-live="polite" aria-atomic="true"></div>
    </div>

    <div class="search-notice">
      <span>ℹ️</span>
      <span>Lista ciudadana en construcción. Si no encuentras a alguien, revisa <a href="https://desaparecidosterremotovenezuela.com/" target="_blank" rel="noopener">desaparecidosterremotovenezuela.com</a> o llama directamente al hospital.</span>
    </div>

    <div class="s-stats" id="global-stats" aria-live="polite"></div>
    <div id="global-results" class="tbl-wrap" style="display:none;margin-bottom:20px" role="region" aria-label="Resultados de búsqueda">
      <table class="tbl">
        <caption class="sr-only">Lista de pacientes encontrados</caption>
        <thead>
          <tr>
            <th scope="col">Nombre</th><th scope="col">Hospital</th><th scope="col">Edad</th><th scope="col">Cédula</th><th scope="col">Dirección</th>
          </tr>
        </thead>
        <tbody id="global-tbody"></tbody>
      </table>
    </div>

    <div class="hosp-accordion" id="hosp-accordion">
      <div style="padding:48px;text-align:center;color:var(--muted)">
        <div style="font-size:36px;margin-bottom:12px">⏳</div>
        <div style="font-size:14px">Cargando lista de pacientes desde Google Sheets...</div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
var SHEET_ID = '1FlFw-guJpiQED_EsR_YJyUhzANy_1HU84_loZqH4_CY';
var API_KEY  = (document.getElementById('hospitales') || {}).dataset.sk || '';
var RANGE    = 'Pacientes!A:H';
// ─── STATE ───────────────────────────────────────────────
let PACIENTES = [];

// ─── UTILS ───────────────────────────────────────────────
function esc(s) {
  return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function norm(s) {
  return (s || '').toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g,'').trim();
}
function hl(t, q) {
  if (!q || !t) return esc(t || '');
  return esc(t).replace(
    new RegExp('(' + q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&') + ')','gi'),
    '<mark class="highlight">$1</mark>'
  );
}
function hospId(name) {
  return 'h_' + name.toLowerCase()
    .normalize('NFD').replace(/[̀-ͯ]/g,'')
    .replace(/[^a-z0-9]+/g,'_')
    .replace(/^_+|_+$/g,'');
}

// ─── ACCORDION ───────────────────────────────────────────
function toggleHosp(hdr, id) {
  const body = document.getElementById(id);
  const open = !body.classList.contains('open');
  body.classList.toggle('open', open);
  hdr.classList.toggle('open', open);
  hdr.setAttribute('aria-expanded', open ? 'true' : 'false');
  if (open && !hdr.dataset.loaded) {
    hdr.dataset.loaded = '1';
    limitRows(id, 20);
  }
}
function limitRows(id, max) {
  const rows = document.querySelectorAll('#list_' + id + ' .patient-row');
  rows.forEach((r, i) => { r.style.display = i < max ? '' : 'none'; });
  const m = document.getElementById('more_' + id);
  if (m) m.style.display = rows.length > max ? '' : 'none';
}
function showAll(id) {
  document.querySelectorAll('#list_' + id + ' .patient-row').forEach(r => { r.style.display = ''; });
  const m = document.getElementById('more_' + id);
  if (m) m.style.display = 'none';
}
function filterHosp(input, id) {
  const q = norm(input.value);
  document.querySelectorAll('#list_' + id + ' .patient-row').forEach(r => {
    r.style.display = (!q || norm(r.dataset.nm || '').includes(q) || norm(r.dataset.ced || '').includes(q)) ? '' : 'none';
  });
  const m = document.getElementById('more_' + id);
  if (m) m.style.display = 'none';
}

// ─── GLOBAL SEARCH ───────────────────────────────────────
function globalSearch(q) {
  const qn = norm(q);
  const wrap = document.getElementById('global-results');
  const tbody = document.getElementById('global-tbody');
  const stats = document.getElementById('global-stats');
  if (!qn || qn.length < 2) { wrap.style.display = 'none'; stats.innerHTML = ''; return; }
  const hits = PACIENTES.filter(p => norm(p.nm).includes(qn) || norm(p.c).includes(qn));
  if (!hits.length) {
    wrap.style.display = 'none';
    stats.innerHTML = 'Sin resultados para <strong>' + esc(q) + '</strong>';
    return;
  }
  tbody.innerHTML = hits.slice(0,100).map(p =>
    '<tr><td class="td-nm">' + hl(p.nm, q) + '</td>'
    + '<td><span class="td-hosp">' + esc(p.h) + '</span></td>'
    + '<td class="td-x">' + (esc(p.e) || '—') + '</td>'
    + '<td class="td-x">' + hl(p.c, q) + '</td>'
    + '<td class="td-x">' + (esc(p.d) || '—') + '</td></tr>'
  ).join('');
  wrap.style.display = '';
  stats.innerHTML = '<strong>' + hits.length + '</strong> resultado' + (hits.length !== 1 ? 's' : '')
    + ' para <strong>' + esc(q) + '</strong>' + (hits.length > 100 ? ' · primeros 100' : '');
}

// ─── CRUCE FAMILIAR ──────────────────────────────────────
function buscarFamiliar() {
  const nombre = norm(document.getElementById('cruce-nombre').value);
  const cedula = document.getElementById('cruce-cedula').value.trim().replace(/[^0-9]/g,'');
  const box = document.getElementById('cruce-results');
  box.style.display = 'block';
  window.dataLayer = window.dataLayer || [];
  window.dataLayer.push({ event: 'buscar_familiar', tipo: cedula ? 'cedula' : 'nombre' });
  if (!nombre && !cedula) {
    box.innerHTML = '<p class="cruce-none">Ingresa un nombre o cédula para buscar.</p>';
    return;
  }
  if (!PACIENTES.length) {
    box.innerHTML = '<p class="cruce-none">Datos cargando, espera un momento...</p>';
    return;
  }
  const matches = [];
  for (const p of PACIENTES) {
    let mN = false, mC = false;
    if (nombre) {
      const words = nombre.split(' ').filter(w => w.length > 2);
      if (words.length) {
        const hits = words.filter(w => norm(p.nm).includes(w));
        mN = hits.length >= Math.min(2, words.length);
      }
    }
    if (cedula && p.c) mC = p.c.replace(/[^0-9]/g,'') === cedula;
    if (mN || mC) matches.push({ ...p, mN, mC });
  }
  if (!matches.length) {
    box.innerHTML = '<div class="cruce-notfound">'
      + '<div class="cruce-notfound-icon">🔍</div>'
      + '<div class="cruce-notfound-title">No encontramos coincidencias</div>'
      + '<div class="cruce-notfound-sub">Puede que aún no esté en la lista o esté registrado con otro nombre. Llama directamente al hospital o repórtalo como desaparecido.</div>'
      + '<a href="https://desaparecidosterremotovenezuela.com/" target="_blank" rel="noopener" class="cruce-notfound-btn">Reportar como desaparecido →</a>'
      + '</div>';
    box.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    return;
  }
  const cards = matches.map(p =>
    '<div class="cruce-card">'
    + '<div class="cruce-card-top">'
    + (p.mC ? '<span class="cruce-match-badge match-cedula">✓ Coincidencia por cédula</span>' : '<span class="cruce-match-badge match-nombre">✓ Coincidencia por nombre</span>')
    + '</div>'
    + '<div class="cruce-card-name">' + esc(p.nm) + '</div>'
    + '<div class="cruce-card-hosp">🏥 ' + esc(p.h) + '</div>'
    + '<div class="cruce-card-meta">'
    + (p.e ? '<span>' + esc(p.e) + ' años</span>' : '')
    + (p.c ? '<span>CI: ' + esc(p.c) + '</span>' : '')
    + (p.d ? '<span>' + esc(p.d) + '</span>' : '')
    + '</div>'
    + '</div>'
  ).join('');
  box.innerHTML = '<div class="cruce-found-header">'
    + '<span class="cruce-found-icon">✅</span>'
    + '<div><div class="cruce-found-count">' + matches.length + ' coincidencia' + (matches.length > 1 ? 's' : '') + ' encontrada' + (matches.length > 1 ? 's' : '') + '</div>'
    + '<div class="cruce-found-sub">Verifica llamando directamente al hospital</div></div>'
    + '</div>'
    + cards;
  box.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}
document.getElementById('cruce-nombre').addEventListener('keydown', e => { if (e.key === 'Enter') buscarFamiliar(); });
document.getElementById('cruce-cedula').addEventListener('keydown', e => { if (e.key === 'Enter') buscarFamiliar(); });

// ─── BUILD ACCORDION ─────────────────────────────────────
function buildAccordion(patients) {
  const byHosp = {};
  for (const p of patients) {
    if (!byHosp[p.h]) byHosp[p.h] = [];
    byHosp[p.h].push(p);
  }
  const container = document.getElementById('hosp-accordion');
  const entries = Object.entries(byHosp);
  if (!entries.length) {
    container.innerHTML = '<div class="no-res">No hay datos en la hoja. Verifica que existan filas en la pestaña "Pacientes".</div>';
    return;
  }
  container.innerHTML = entries.map(([hosp, pts]) => {
    const id = hospId(hosp);
    const isRefugio = /acopio|refugio|golf|campo/i.test(hosp);
    const panelStyle = isRefugio ? 'border-color:#F59E0B' : '';
    const headerBg = isRefugio ? 'background:#FEF8EE' : '';
    const icon = isRefugio ? '🏕️' : '🏥';
    const label = isRefugio ? 'personas' : 'pacientes';
    const badgeStyle = isRefugio ? 'background:#FEF3CD;color:#92400E' : '';
    const bodyBorder = isRefugio ? 'border-top:1px solid #F59E0B' : '';
    const searchBg = isRefugio ? 'background:#FFFBEB' : '';
    const warning = isRefugio
      ? '<div style="background:#FFFBEB;padding:10px 16px;font-size:12px;color:#92400E;border-bottom:1px solid #F59E0B">⚠️ Estas personas <strong>no están hospitalizadas</strong> — se encuentran en un centro de acopio.</div>'
      : '';
    const rowsHtml = pts.map(p => {
      const nmKey = norm(p.nm);
      const cedKey = (p.c || '').replace(/[^0-9]/g,'');
      return '<li class="patient-row" data-nm="' + esc(nmKey) + '" data-ced="' + esc(cedKey) + '">'
        + '<div>'
        + '<div class="patient-nm">' + esc(p.nm) + '</div>'
        + (p.d ? '<div class="patient-detail">' + esc(p.d) + '</div>' : '')
        + '</div>'
        + '<div class="patient-tags">'
        + (isRefugio ? '<span class="ptag" style="background:#FEF3CD;color:#92400E">Refugio</span>' : '')
        + (p.e ? '<span class="ptag ptag-age">' + esc(p.e) + '</span>' : '')
        + (p.c && !isRefugio ? '<span class="ptag ptag-ced">' + esc(p.c) + '</span>' : '')
        + '</div>'
        + '</li>';
    }).join('');
    return '<div class="hosp-panel" style="' + panelStyle + '">'
      + '<button class="hosp-header" onclick="toggleHosp(this,\'' + id + '\')" style="' + headerBg + '" aria-expanded="false" aria-controls="' + id + '" type="button">'
      + '<div class="hosp-header-left">'
      + '<span class="hosp-name" aria-hidden="true">' + icon + '</span> <span class="hosp-name">' + esc(hosp) + '</span>'
      + '<span class="hosp-badge" style="' + badgeStyle + '">' + pts.length + ' ' + label + '</span>'
      + '</div>'
      + '<span class="hosp-chevron" aria-hidden="true">▼</span>'
      + '</button>'
      + '<div class="hosp-body" id="' + id + '" style="' + bodyBorder + '">'
      + '<div class="hosp-search-row" style="' + searchBg + '">'
      + '<label class="sr-only" for="search_' + id + '">Buscar en ' + esc(hosp) + '</label>'
      + '<input class="hosp-search" type="search" id="search_' + id + '" aria-label="Buscar en ' + esc(hosp) + '" placeholder="Buscar en este ' + (isRefugio ? 'refugio' : 'hospital') + '..." oninput="filterHosp(this,\'' + id + '\')" autocomplete="off" autocorrect="off" spellcheck="false"/>'
      + '</div>'
      + warning
      + '<ul class="patient-list" id="list_' + id + '">' + rowsHtml + '</ul>'
      + '<div class="hosp-show-more" id="more_' + id + '" style="display:none">'
      + '<button onclick="showAll(\'' + id + '\')">Ver los ' + pts.length + ' ' + label + ' ↓</button>'
      + '</div>'
      + '</div>'
      + '</div>';
  }).join('');
}

// ─── LOAD DATA ───────────────────────────────────────────
async function loadPatients() {
  const accordion = document.getElementById('hosp-accordion');
  try {
    if (!SHEET_ID || !API_KEY) {
      accordion.innerHTML = '<div class="no-res">Configuración de Google Sheets no encontrada.</div>';
      return;
    }
    const url = 'https://sheets.googleapis.com/v4/spreadsheets/' + SHEET_ID + '/values/' + encodeURIComponent(RANGE) + '?key=' + API_KEY;
    const res = await fetch(url);
    if (!res.ok) {
      const txt = await res.text();
      throw new Error('Sheets API ' + res.status + ': ' + txt.slice(0, 200));
    }
    const data = await res.json();
    const rows = data.values || [];
    PACIENTES = rows.slice(1).filter(function(row) { return row[2] && row[2].trim(); }).map(function(row, i) {
      return {
        n: i + 1,
        h: (row[1] || '').trim(),
        nm: (row[2] || '').trim().toUpperCase(),
        e: (row[3] || '').trim(),
        c: (row[4] || '').trim(),
        t: (row[5] || '').trim(),
        d: (row[6] || '').trim(),
        o: (row[7] || '').trim(),
      };
    });
    buildAccordion(PACIENTES);
    const total = PACIENTES.length;
    const centers = new Set(PACIENTES.map(function(p) { return p.h; })).size;
    const nowDate = new Date();
    const dateStr = nowDate.toLocaleDateString('es-VE', { day: 'numeric', month: 'short', year: 'numeric' });
    const timeStr = nowDate.toLocaleTimeString('es-VE', { hour: '2-digit', minute: '2-digit' });
    const heroEl = document.getElementById('pacientes-stats-hero');
    if (heroEl) {
      const chip = function(val, label, cls) {
        return '<div class="stat-chip' + (cls ? ' ' + cls : '') + '">'
          + '<div class="stat-val">' + val + '</div>'
          + '<div class="stat-label">' + label + '</div>'
          + '</div>';
      };
      heroEl.innerHTML = chip(total.toLocaleString('es-VE'), 'registros')
        + chip(centers, 'centros de salud')
        + chip(dateStr + ' · ' + timeStr, 'actualizado', 'stat-chip-date');
    }
  } catch (err) {
    console.error('[Buscador]', err);
    accordion.innerHTML = '<div class="no-res" style="font-size:13px">'
      + 'Error: ' + String(err) + '<br><br>'
      + 'SheetID: ' + (SHEET_ID ? SHEET_ID.slice(0,8) + '...' : 'VACIO') + '<br>'
      + 'APIKey: ' + (API_KEY ? API_KEY.slice(0,8) + '...' : 'VACIO') + '<br><br>'
      + '<button onclick="loadPatients()" style="color:var(--blue);font-weight:700;background:none;border:none;cursor:pointer">Reintentar →</button></div>';
  }
}

// ─── NAV ACTIVE ──────────────────────────────────────────
document.querySelectorAll('section[id]').forEach(function(s) {
  new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (e.isIntersecting) {
        document.querySelectorAll('#main-nav a').forEach(function(l) {
          l.classList.toggle('active', l.getAttribute('href') === '#' + e.target.id);
        });
      }
    });
  }, { threshold: 0.25 }).observe(s);
});

// ─── SMOOTH SCROLL ───────────────────────────────────────
document.querySelectorAll('a[href^="#"]').forEach(function(a) {
  a.addEventListener('click', function(e) {
    const t = document.querySelector(a.getAttribute('href'));
    if (t) { e.preventDefault(); t.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
  });
});

loadPatients();
</script>
