---
const sheetsKey = import.meta.env.PUBLIC_SHEETS_KEY ?? '';
const webhookUrl = import.meta.env.PUBLIC_EB_WEBHOOK ?? '';
---
<section id="estoy-bien" data-sk={sheetsKey} data-wh={webhookUrl}>
  <div class="container">

    <!-- HERO DE LA SECCIÓN -->
    <div class="eb-hero">
      <div class="eb-hero-text">
        <div class="s-eye">✅ Estoy Bien</div>
        <h2 class="s-title">Reconectemos a cada familia.</h2>
        <p class="s-sub">Tras el terremoto, muchas familias siguen sin saber de los suyos. Si estás bien, avisa aquí — para que tu nombre dé tranquilidad, no angustia.</p>
      </div>
      <button class="eb-cta-btn" onclick="abrirModalEB()">
        + &nbsp; Avisar que estoy bien
      </button>
      <p class="eb-cta-note">Tu publicación será revisada antes de aparecer. Tarda menos de 2 minutos.</p>
    </div>

    <!-- CARRUSEL EN VIVO -->
    <div class="eb-live-section">
      <div class="eb-live-header">
        <span class="eb-live-pulse"></span>
        <span class="eb-live-label">EN VIVO — Mensajes recientes</span>
        <span class="eb-live-count" id="eb-live-count"></span>
      </div>
      <div class="eb-cards-outer">
        <div class="eb-cards-track" id="eb-cards-track">
          <div class="eb-loading">Cargando mensajes...</div>
        </div>
      </div>
    </div>

    <!-- BUSCADOR -->
    <div class="eb-search-box">
      <h3 class="eb-box-title">🔍 Buscar a alguien</h3>
      <div class="eb-search-form">
        <label for="eb-search" class="sr-only">Buscar por nombre o cédula</label>
        <input type="text" id="eb-search" class="cruce-input" placeholder="Nombre completo o cédula..." autocomplete="off" autocorrect="off" spellcheck="false"/>
        <button class="btn-amber" onclick="buscarEB()">Buscar</button>
      </div>
      <div id="eb-search-res" aria-live="polite"></div>
    </div>

  </div>
</section>

<!-- MODAL DEL FORMULARIO -->
<div id="eb-modal-overlay" class="eb-modal-overlay" onclick="cerrarModalEB(event)" aria-modal="true" role="dialog" aria-label="Formulario Estoy Bien" hidden>
  <div class="eb-modal">
    <div class="eb-modal-header">
      <div>
        <div class="eb-modal-title">✅ Avisar que estoy bien</div>
        <div class="eb-modal-sub">Completa el formulario y revisaremos tu publicación.</div>
      </div>
      <button class="eb-modal-close" onclick="cerrarModalEB()" aria-label="Cerrar">&times;</button>
    </div>

    <div class="eb-modal-body">
      <form id="eb-form" onsubmit="submitEB(event)" novalidate>

        <div class="eb-form-grid">
          <div class="eb-field">
            <label for="eb-nombre">Nombre completo <span class="eb-req">*</span></label>
            <input type="text" id="eb-nombre" name="nombre" class="eb-input" placeholder="Ej. María García" required autocomplete="name"/>
          </div>
          <div class="eb-field">
            <label for="eb-cedula">Cédula de identidad <span class="eb-req">*</span></label>
            <input type="text" id="eb-cedula" name="cedula" class="eb-input" placeholder="Ej. V-12345678" required/>
          </div>
          <div class="eb-field">
            <label for="eb-edad">Edad <span class="eb-req">*</span></label>
            <input type="number" id="eb-edad" name="edad" class="eb-input" placeholder="Ej. 35" min="1" max="120" required/>
          </div>
          <div class="eb-field">
            <label for="eb-sexo">Sexo <span class="eb-req">*</span></label>
            <select id="eb-sexo" name="sexo" class="eb-input" required>
              <option value="">Seleccionar...</option>
              <option value="Femenino">Femenino</option>
              <option value="Masculino">Masculino</option>
            </select>
          </div>
          <div class="eb-field">
            <label for="eb-estado-vzla">Estado <span class="eb-req">*</span></label>
            <select id="eb-estado-vzla" name="estado_vzla" class="eb-input" required>
              <option value="">Seleccionar...</option>
              <option>Amazonas</option><option>Anzoátegui</option><option>Apure</option>
              <option>Aragua</option><option>Barinas</option><option>Bolívar</option>
              <option>Carabobo</option><option>Cojedes</option><option>Delta Amacuro</option>
              <option>Distrito Capital</option><option>Falcón</option><option>Guárico</option>
              <option>La Guaira</option><option>Lara</option><option>Mérida</option>
              <option>Miranda</option><option>Monagas</option><option>Nueva Esparta</option>
              <option>Portuguesa</option><option>Sucre</option><option>Táchira</option>
              <option>Trujillo</option><option>Yaracuy</option><option>Zulia</option>
            </select>
          </div>
          <div class="eb-field">
            <label for="eb-ciudad">Ciudad / Municipio</label>
            <input type="text" id="eb-ciudad" name="ciudad" class="eb-input" placeholder="Escribe tu ciudad..."/>
          </div>
          <div class="eb-field eb-field-full">
            <label for="eb-tipo-lugar">¿Dónde te encuentras? <span class="eb-req">*</span></label>
            <select id="eb-tipo-lugar" name="tipo_lugar" class="eb-input" required>
              <option value="">Seleccionar...</option>
              <option value="Casa propia">Casa propia</option>
              <option value="Casa de familiar">Casa de familiar</option>
              <option value="Refugio / Albergue">Refugio / Albergue</option>
              <option value="Hospital / Centro de salud">Hospital / Centro de salud</option>
              <option value="Otro">Otro</option>
            </select>
          </div>
          <div class="eb-field eb-field-full">
            <label for="eb-direccion">Dirección o punto de referencia <span class="eb-req">*</span></label>
            <input type="text" id="eb-direccion" name="direccion" class="eb-input" placeholder="Ej. Av. Principal de La Castellana, cerca del CCCT" required/>
          </div>
        </div>

        <div class="eb-status-group">
          <label class="eb-status-label">¿Cómo estás? <span class="eb-req">*</span></label>
          <div class="eb-status-options">
            <label class="eb-status-opt eb-opt-bien">
              <input type="radio" name="status" value="estoy_bien" required/>
              <span class="eb-opt-icon">✅</span>
              <span class="eb-opt-text">Estoy bien</span>
            </label>
            <label class="eb-status-opt eb-opt-recuperacion">
              <input type="radio" name="status" value="recuperacion"/>
              <span class="eb-opt-icon">🟡</span>
              <span class="eb-opt-text">En recuperación</span>
            </label>
            <label class="eb-status-opt eb-opt-ayuda">
              <input type="radio" name="status" value="necesita_ayuda"/>
              <span class="eb-opt-icon">🆘</span>
              <span class="eb-opt-text">Necesito ayuda</span>
            </label>
          </div>
        </div>

        <div class="eb-field eb-field-full" id="eb-necesita-wrap" style="display:none;margin-bottom:14px">
          <label for="eb-que-necesita">¿Qué necesitas? <span class="eb-req">*</span></label>
          <input type="text" id="eb-que-necesita" name="que_necesita" class="eb-input" placeholder="Ej. Medicamentos para diabetes, agua, alimentos"/>
        </div>

        <div class="eb-form-grid">
          <div class="eb-field eb-field-full">
            <label for="eb-mensaje">Mensaje para tu familia <span class="eb-req">*</span></label>
            <textarea id="eb-mensaje" name="mensaje" class="eb-input eb-textarea" placeholder="Ej. Estoy en casa de mi tía en Los Palos Grandes, estamos todos bien. No se preocupen." maxlength="300" required></textarea>
            <div class="eb-char-count"><span id="eb-char">0</span>/300</div>
          </div>
          <div class="eb-field">
            <label for="eb-telefono">Teléfono / WhatsApp</label>
            <input type="tel" id="eb-telefono" name="telefono" class="eb-input" placeholder="Ej. 0414-1234567"/>
          </div>
          <div class="eb-field">
            <label for="eb-red-social">Instagram o Facebook (opcional)</label>
            <input type="text" id="eb-red-social" name="red_social" class="eb-input" placeholder="Ej. @maria.garcia"/>
          </div>
        </div>

        <div id="eb-form-msg" aria-live="polite"></div>

        <button type="submit" class="eb-submit-btn" id="eb-submit">
          Publicar mi mensaje
        </button>

      </form>
    </div>
  </div>
</div>

<script is:inline>
(function () {
  var SEC     = document.getElementById('estoy-bien');
  var SHEET_ID = '1FlFw-guJpiQED_EsR_YJyUhzANy_1HU84_loZqH4_CY';
  var API_KEY  = SEC ? SEC.dataset.sk : '';
  var WEBHOOK  = SEC ? SEC.dataset.wh : '';
  var RANGE    = 'EstoyBien!A:O';
  var EB_DATA  = [];

  var STATUS_LABEL = { estoy_bien: 'Estoy bien', recuperacion: 'En recuperación', necesita_ayuda: 'Necesita ayuda' };
  var STATUS_CLASS = { estoy_bien: 'eb-tag-bien', recuperacion: 'eb-tag-rec', necesita_ayuda: 'eb-tag-ayuda' };

  // ── MODAL ──────────────────────────────────────────────────
  window.abrirModalEB = function() {
    var overlay = document.getElementById('eb-modal-overlay');
    overlay.hidden = false;
    document.body.style.overflow = 'hidden';
    overlay.querySelector('.eb-modal').scrollTop = 0;
  };

  window.cerrarModalEB = function(e) {
    if (e && e.target !== document.getElementById('eb-modal-overlay')) return;
    var overlay = document.getElementById('eb-modal-overlay');
    overlay.hidden = true;
    document.body.style.overflow = '';
  };

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      var overlay = document.getElementById('eb-modal-overlay');
      if (!overlay.hidden) {
        overlay.hidden = true;
        document.body.style.overflow = '';
      }
    }
  });

  // ── LOAD DATA ──────────────────────────────────────────────
  function loadEB() {
    if (!API_KEY) return;
    var url = 'https://sheets.googleapis.com/v4/spreadsheets/' + SHEET_ID + '/values/'
      + encodeURIComponent(RANGE) + '?key=' + API_KEY;
    fetch(url)
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var rows = data.values || [];
        if (rows.length && rows[0][0] === 'timestamp') rows = rows.slice(1);
        EB_DATA = rows
          .filter(function(r) { return r[14] === 'aprobado'; })
          .map(function(r) {
            return {
              ts: r[0] || '', nm: r[1] || '', ced: r[2] || '', edad: r[3] || '',
              sexo: r[4] || '', estado: r[5] || '', ciudad: r[6] || '',
              tipo: r[7] || '', dir: r[8] || '', status: r[9] || 'estoy_bien',
              necesita: r[10] || '', msg: r[11] || '', tel: r[12] || '',
              red: r[13] || ''
            };
          })
          .reverse();
        buildCarousel();
        var cnt = document.getElementById('eb-live-count');
        if (cnt) cnt.textContent = EB_DATA.length + ' publicación' + (EB_DATA.length !== 1 ? 'es' : '');
      })
      .catch(function() {});
  }

  // ── CAROUSEL ───────────────────────────────────────────────
  function timeAgo(ts) {
    if (!ts) return '';
    var diff = (Date.now() - new Date(ts).getTime()) / 60000;
    if (diff < 1) return 'Ahora mismo';
    if (diff < 60) return 'Hace ' + Math.floor(diff) + ' min';
    if (diff < 1440) return 'Hace ' + Math.floor(diff / 60) + 'h';
    return 'Hace ' + Math.floor(diff / 1440) + ' día(s)';
  }

  function buildCarousel() {
    var track = document.getElementById('eb-cards-track');
    if (!track) return;
    if (!EB_DATA.length) {
      track.innerHTML = '<div class="eb-empty">Sé el primero en publicar tu mensaje.</div>';
      return;
    }
    track.innerHTML = EB_DATA.slice(0, 30).map(function(p) {
      return '<div class="eb-card">'
        + '<div class="eb-card-top">'
        + '<span class="eb-tag ' + (STATUS_CLASS[p.status] || 'eb-tag-bien') + '">' + (STATUS_LABEL[p.status] || '') + '</span>'
        + '<span class="eb-card-time">' + timeAgo(p.ts) + '</span>'
        + '</div>'
        + '<div class="eb-card-name">' + esc(p.nm) + '</div>'
        + '<div class="eb-card-loc">📍 ' + esc(p.ciudad) + (p.estado ? ', ' + esc(p.estado) : '') + ' · ' + esc(p.tipo) + '</div>'
        + (p.msg ? '<div class="eb-card-msg">"' + esc(p.msg) + '"</div>' : '')
        + (p.necesita ? '<div class="eb-card-necesita">🆘 ' + esc(p.necesita) + '</div>' : '')
        + '</div>';
    }).join('');
  }

  // ── SEARCH ─────────────────────────────────────────────────
  window.buscarEB = function() {
    var q = document.getElementById('eb-search').value.trim().toLowerCase()
      .normalize('NFD').replace(/[̀-ͯ]/g,'');
    var res = document.getElementById('eb-search-res');
    if (!q || q.length < 2) { res.innerHTML = ''; return; }
    var hits = EB_DATA.filter(function(p) {
      return p.nm.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g,'').includes(q)
        || p.ced.replace(/[^0-9]/g,'').includes(q.replace(/[^0-9]/g,''));
    });
    if (!hits.length) {
      res.innerHTML = '<div class="cruce-notfound"><div class="cruce-notfound-icon">🔍</div>'
        + '<div class="cruce-notfound-title">No encontramos a esa persona</div>'
        + '<div class="cruce-notfound-sub">Puede que aún no haya publicado su mensaje.</div></div>';
      return;
    }
    res.innerHTML = '<div class="cruce-found-header">'
      + '<span class="cruce-found-icon">✅</span>'
      + '<div><div class="cruce-found-count">' + hits.length + ' resultado' + (hits.length > 1 ? 's' : '') + '</div>'
      + '<div class="cruce-found-sub">Verifica el contacto directo con la persona</div></div></div>'
      + hits.map(function(p) {
        return '<div class="cruce-card">'
          + '<div class="cruce-card-top"><span class="eb-tag ' + (STATUS_CLASS[p.status] || '') + '">' + (STATUS_LABEL[p.status] || '') + '</span></div>'
          + '<div class="cruce-card-name">' + esc(p.nm) + '</div>'
          + '<div class="cruce-card-hosp">📍 ' + esc(p.ciudad) + (p.estado ? ', ' + esc(p.estado) : '') + ' · ' + esc(p.tipo) + '</div>'
          + (p.msg ? '<div class="eb-card-msg" style="margin-top:8px;font-size:13px;color:#475569">"' + esc(p.msg) + '"</div>' : '')
          + '<div class="cruce-card-meta">'
          + (p.edad ? '<span>' + esc(p.edad) + ' años</span>' : '')
          + (p.sexo ? '<span>' + esc(p.sexo) + '</span>' : '')
          + (p.tel ? '<span>📱 ' + esc(p.tel) + '</span>' : '')
          + '</div></div>';
      }).join('');
    res.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  };

  // ── FORM SUBMIT ────────────────────────────────────────────
  window.submitEB = function(e) {
    e.preventDefault();
    var msg = document.getElementById('eb-form-msg');
    var btn = document.getElementById('eb-submit');
    if (!WEBHOOK) {
      msg.innerHTML = '<div class="eb-msg-error">Servicio de envío no configurado aún. Vuelve pronto.</div>';
      return;
    }
    var form = document.getElementById('eb-form');
    var data = {};
    new FormData(form).forEach(function(v, k) { data[k] = v; });
    if (!data.nombre || !data.cedula || !data.edad || !data.sexo || !data.estado_vzla
        || !data.tipo_lugar || !data.direccion || !data.status || !data.mensaje) {
      msg.innerHTML = '<div class="eb-msg-error">Por favor completa todos los campos obligatorios.</div>';
      return;
    }
    btn.disabled = true;
    btn.textContent = 'Enviando...';
    fetch(WEBHOOK, {
      method: 'POST',
      headers: { 'Content-Type': 'text/plain' },
      body: JSON.stringify(data)
    })
    .then(function(r) { return r.json(); })
    .then(function(res) {
      if (res.ok) {
        form.reset();
        document.getElementById('eb-necesita-wrap').style.display = 'none';
        document.getElementById('eb-char').textContent = '0';
        msg.innerHTML = '<div class="eb-msg-ok">✅ Mensaje enviado. Aparecerá en la página una vez revisado. ¡Gracias!</div>';
        setTimeout(function() {
          document.getElementById('eb-modal-overlay').hidden = true;
          document.body.style.overflow = '';
          msg.innerHTML = '';
        }, 3000);
      } else {
        throw new Error(res.error || 'Error');
      }
    })
    .catch(function() {
      msg.innerHTML = '<div class="eb-msg-error">Hubo un error al enviar. Intenta de nuevo.</div>';
    })
    .finally(function() {
      btn.disabled = false;
      btn.textContent = 'Publicar mi mensaje';
    });
  };

  // ── UTILS ──────────────────────────────────────────────────
  function esc(s) {
    return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  // ── EVENTS ─────────────────────────────────────────────────
  document.querySelectorAll('input[name="status"]').forEach(function(r) {
    r.addEventListener('change', function() {
      var wrap = document.getElementById('eb-necesita-wrap');
      wrap.style.display = this.value === 'necesita_ayuda' ? 'block' : 'none';
      document.getElementById('eb-que-necesita').required = this.value === 'necesita_ayuda';
    });
  });

  var textarea = document.getElementById('eb-mensaje');
  if (textarea) {
    textarea.addEventListener('input', function() {
      document.getElementById('eb-char').textContent = this.value.length;
    });
  }

  document.getElementById('eb-search').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') buscarEB();
  });

  // ── INIT ───────────────────────────────────────────────────
  loadEB();
  setInterval(loadEB, 30000);
})();
</script>
