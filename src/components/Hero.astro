<section class="hero">
  <div class="hero-eye" aria-hidden="true">🇻🇪 Información centralizada — Sismo Venezuela 2026</div>
  <h1>Busca. Reporta.<br><em>Ayuda.</em></h1>
  <p>Encuentra personas hospitalizadas, sube listas de centros de salud, localiza centros de acopio y dona sangre. Todo en un lugar.</p>

  <div class="functions">

    <!-- Jornadas de sangre — carrusel vertical -->
    <div class="fn-blood-card" role="region" aria-label="Jornadas de Donación de Sangre">
      <div class="fn-blood-header">
        <span class="fn-blood-pulse" aria-hidden="true"></span>
        <span class="fn-blood-label">JORNADAS ACTIVAS</span>
      </div>
      <h2 class="fn-blood-title" id="fn-card-title">Donar Sangre</h2>

      <div class="fn-carousel-wrap">
        <div class="fn-carousel-track" id="fn-track">

          <div class="fn-slide" role="group" aria-label="Jornada 1 de 3">
            <div class="fn-slide-org">Centro Médico de Caracas</div>
            <div class="fn-slide-name">Jornada Solidaria<br>#SismoVenezuela</div>
            <div class="fn-slide-row"><span aria-hidden="true">📅</span> Sáb 27 de junio</div>
            <div class="fn-slide-row"><span aria-hidden="true">🕐</span> 8:00 AM – 2:00 PM</div>
            <div class="fn-slide-row"><span aria-hidden="true">📍</span> Jardín Cincuentenario<br><span class="fn-slide-sub">Edf. Principal, Centro Médico</span></div>
            <div class="fn-slide-badge">1 donante salva 3 vidas</div>
          </div>

          <div class="fn-slide" role="group" aria-label="Jornada 2 de 3">
            <div class="fn-slide-org">IVSS · Ministerio de Trabajo</div>
            <div class="fn-slide-name">Jornada Donantes<br>Voluntarios</div>
            <div class="fn-slide-row"><span aria-hidden="true">📅</span> 26 al 28 de junio</div>
            <div class="fn-slide-row"><span aria-hidden="true">🕐</span> Desde las 8:00 AM</div>
            <div class="fn-slide-row"><span aria-hidden="true">📍</span> Hemocentro Chacao</div>
            <div class="fn-slide-row"><span aria-hidden="true">📍</span> Hosp. Domingo Luciani</div>
            <div class="fn-slide-row"><span aria-hidden="true">📍</span> Hospital Pérez Carreño</div>
          </div>

          <div class="fn-slide fn-slide-green" role="group" aria-label="Slide 3 de 4">
            <div class="fn-slide-org">Terrazas de San Diego · Carabobo</div>
            <div class="fn-slide-name">Detrás del CC Fin de Siglo</div>
            <div class="fn-slide-needs">Necesitamos <span aria-hidden="true">!</span></div>
            <ul class="fn-slide-items">
              <li>Velas</li>
              <li>Sábanas</li>
              <li>Acetaminofén ped.</li>
              <li>Cetirizina ped.</li>
              <li>Crema de arroz</li>
              <li>Diclofenac</li>
              <li>Agua</li>
              <li>Anticonvulsivo</li>
              <li>Pañales adulto</li>
              <li>Valsartan</li>
            </ul>
            <div class="fn-slide-badge">Cualquier donativo cuenta</div>
          </div>

          <div class="fn-slide fn-slide-bambi" role="group" aria-label="Slide 4 de 5">
            <div class="fn-slide-bambi-header">
              <img src="/logo-hogar-bambi.png" alt="Hogar Bambi Venezuela" class="fn-bambi-logo"/>
              <div>
                <div class="fn-slide-org" style="color:#166534">Hogar Bambi Venezuela</div>
                <div class="fn-slide-name" style="color:#14532D">Niños rescatados necesitan ayuda</div>
              </div>
            </div>
            <div class="fn-slide-needs" style="color:#166534">Requerimos urgente:</div>
            <ul class="fn-slide-items fn-slide-items-bambi">
              <li>Gasoil</li>
              <li>Pediasure / Ensure</li>
              <li>Leche fórmula infantil</li>
              <li>Nestum / Cerelac</li>
              <li>Pañales y toallitas</li>
              <li>Ropa interior / pijamas</li>
              <li>Guantes y gasas</li>
              <li>Ibuprofeno / atamel</li>
              <li>Colchones / sábanas</li>
              <li>Agua y alimentos</li>
            </ul>
            <div class="fn-slide-bambi-footer">
              <div class="fn-slide-row" style="font-size:11px;color:#166534"><span aria-hidden="true">📍</span> Hogar Bambi IV, Calle Oriente #13, San Bernardino · 8AM–4PM</div>
              <div class="fn-slide-bambi-links">
                <a href="https://www.instagram.com/edgarramirez25" target="_blank" rel="noopener" class="fn-bambi-ig">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                  @edgarramirez25
                </a>
                <a href="https://hogarbambi.org/" target="_blank" rel="noopener" class="fn-bambi-web">hogarbambi.org →</a>
              </div>
            </div>
          </div>

          <div class="fn-slide fn-slide-green" role="group" aria-label="Slide 5 de 5">
            <div class="fn-slide-org">Parque del Este · Caracas</div>
            <div class="fn-slide-name">¿Qué llevar al punto de acopio?</div>
            <div class="fn-slide-row"><span aria-hidden="true">✅</span> <strong>Insumos médicos</strong> — lo más urgente</div>
            <div class="fn-slide-row"><span aria-hidden="true">🥫</span> Comida <strong>no perecedera</strong></div>
            <div class="fn-slide-row"><span aria-hidden="true">💧</span> Agua embotellada</div>
            <div class="fn-slide-badge fn-slide-badge-warn"><span aria-hidden="true">🚫</span> No traigan más ropa — hay suficiente en La Guaira</div>
          </div>

        </div>
      </div>

      <div class="fn-dots" role="tablist" aria-label="Navegación del carrusel">
        <button class="fn-dot fn-dot-on" onclick="fnGo(0)" aria-label="Jornada 1" role="tab" aria-selected="true"></button>
        <button class="fn-dot" onclick="fnGo(1)" aria-label="Jornada 2" role="tab" aria-selected="false"></button>
        <button class="fn-dot" onclick="fnGo(2)" aria-label="Terrazas de San Diego" role="tab" aria-selected="false"></button>
        <button class="fn-dot" onclick="fnGo(3)" aria-label="Hogar Bambi" role="tab" aria-selected="false"></button>
        <button class="fn-dot" onclick="fnGo(4)" aria-label="Parque del Este" role="tab" aria-selected="false"></button>
      </div>

      <a href="#sangre" class="fn-blood-link">Ver todos los bancos de sangre →</a>
    </div>

    <!-- Cards 2×2 -->
    <a href="#hospitales" class="fn-card fn-1">
      <span class="fn-icon" aria-hidden="true">🏥</span>
      <h2>Buscar en hospitales</h2>
      <p>Registros en tiempo real · hospitales y refugios</p>
    </a>
    <a href="#subir-lista" class="fn-card fn-2">
      <span class="fn-icon" aria-hidden="true">📤</span>
      <h2>Subir lista de pacientes</h2>
      <p>Sube una foto o Excel de tu centro de salud</p>
    </a>
    <a href="#sangre" class="fn-card fn-4">
      <span class="fn-icon" aria-hidden="true">🩸</span>
      <h2>Donar sangre</h2>
      <p>Bancos de sangre activos en Venezuela</p>
    </a>
    <a href="#psicologia" class="fn-card fn-5">
      <span class="fn-icon" aria-hidden="true">🧠</span>
      <h2>Apoyo psicológico</h2>
      <p>Recursos gratuitos para sobrevivientes y familias</p>
    </a>

  </div>
</section>

<script is:inline>
(function () {
  var cur = 0, tot = 5, timer;
  var fnTitles = ['Donar Sangre', 'Donar Sangre', 'Centro de Acopio', 'Hogar Bambi', 'Centro de Acopio'];
  var fnLinks  = [
    { text: 'Ver todos los bancos de sangre →', href: '#sangre' },
    { text: 'Ver todos los bancos de sangre →', href: '#sangre' },
    { text: 'Ver más sobre qué donar →',        href: '#que-donar' },
    { text: 'Visitar hogarbambi.org →',         href: 'https://hogarbambi.org/' },
    { text: 'Ver más sobre qué donar →',        href: '#que-donar' }
  ];

  function fnGo(n) {
    cur = n;
    var t = document.getElementById('fn-track');
    if (t) t.style.transform = 'translateX(-' + n * 100 + '%)';
    document.querySelectorAll('.fn-dot').forEach(function (d, i) {
      d.classList.toggle('fn-dot-on', i === n);
      d.setAttribute('aria-selected', i === n ? 'true' : 'false');
    });
    var titleEl = document.getElementById('fn-card-title');
    if (titleEl) titleEl.textContent = fnTitles[n];
    var linkEl = document.querySelector('.fn-blood-link');
    if (linkEl) { linkEl.textContent = fnLinks[n].text; linkEl.href = fnLinks[n].href; }
  }
  function fnNext() { fnGo((cur + 1) % tot); }

  window.fnGo = fnGo;
  timer = setInterval(fnNext, 5000);

  var wrap = document.querySelector('.fn-carousel-wrap');
  if (wrap) {
    wrap.addEventListener('mouseenter', function () { clearInterval(timer); });
    wrap.addEventListener('mouseleave', function () { timer = setInterval(fnNext, 5000); });
  }
})();
</script>
