---
---
<section id="subir-lista">
  <div class="container">
    <div class="s-eye">📤 Función 02</div>
    <h2 class="s-title">Sube una lista de tu centro de salud</h2>
    <p class="s-sub">¿Trabajas en un hospital o eres voluntario? Envíanos la información. La publicamos en menos de una hora.</p>

    <div class="upload-hero">
      <div class="upload-hero-icon">📋</div>
      <div>
        <h3>Llena el formulario y te decimos cómo enviar el archivo.</h3>
        <p>Registra el centro de salud y tu contacto. Luego te indicamos cómo enviarnos la lista en Excel, PDF o Word.</p>
      </div>
    </div>

    <div class="upload-card">
      <form id="lista-form" onsubmit="submitLista(event)">
        <input type="hidden" name="access_key" value="2e9662c3-5b13-4027-9492-f26d61908710"/>
        <input type="hidden" name="subject" value="Nueva lista de pacientes — Red Solidaria Venezuela"/>
        <input type="hidden" name="from_name" value="Red Solidaria Venezuela"/>
        <div class="form-row">
          <div class="form-group full">
            <label class="f-label" for="f-hospital">Centro de salud <span class="req">*</span></label>
            <input type="text" id="f-hospital" name="hospital" class="f-input"
              placeholder="Ej: Hospital Vargas, Clínica El Ávila, Cruz Roja Táchira..." required/>
          </div>
          <div class="form-group">
            <label class="f-label" for="f-reporte">Tipo de reporte</label>
            <select id="f-reporte" name="tipo_reporte" class="f-select">
              <option value="">Selecciona...</option>
              <option value="pacientes-hospitalizados">Pacientes hospitalizados</option>
              <option value="pacientes-fallecidos">Pacientes fallecidos</option>
              <option value="dados-de-alta">Dados de alta</option>
              <option value="heridos-leves">Heridos leves atendidos</option>
              <option value="lista-parcial">Lista parcial / incompleta</option>
            </select>
          </div>
          <div class="form-group">
            <label class="f-label" for="f-contacto">Tu correo o teléfono <span class="req">*</span></label>
            <input type="text" id="f-contacto" name="contacto" class="f-input" placeholder="Para confirmarte cuando lo publiquemos" required/>
          </div>
        </div>

        <div class="upload-footer">
          <button type="submit" class="btn-blue" id="submit-btn"
            style="font-size:16px;padding:14px 28px">
            Registrar centro de salud →
          </button>
        </div>
      </form>

      <div class="upload-ok" id="upload-ok" style="display:none">
        <div class="ok-icon">✅</div>
        <h4>¡Registro recibido!</h4>
        <p>Ahora envíanos la lista de pacientes por correo. Adjunta el archivo (Excel, PDF o Word) y escribe el nombre del hospital en el asunto.</p>
        <a id="mailto-link" href="mailto:info@redsolidariavenezuela.com"
          style="display:inline-flex;align-items:center;gap:8px;background:#1A4F91;color:#fff;font-size:15px;font-weight:700;padding:13px 24px;border-radius:8px;text-decoration:none;margin-top:8px">
          📧 Enviar archivo por correo →
        </a>
        <p style="font-size:12px;color:var(--muted);margin-top:12px">El correo se abre con el asunto y destinatario listos. Solo adjunta el archivo y envía.</p>
      </div>
    </div>
  </div>
</section>

<script is:inline>
function submitLista(e) {
  e.preventDefault();
  const btn = document.getElementById('submit-btn');
  btn.textContent = 'Enviando...';
  btn.disabled = true;
  const hospital = document.getElementById('f-hospital').value;
  const reporte  = document.getElementById('f-reporte').value;
  const data = new FormData(document.getElementById('lista-form'));
  fetch('https://formspree.io/f/xkolrddo', {
    method: 'POST',
    body: data,
    headers: { 'Accept': 'application/json' }
  })
  .then(res => res.json())
  .then(json => {
    if (json.ok || json.next) {
      const subject = encodeURIComponent('Lista pacientes — ' + hospital + (reporte ? ' · ' + reporte : ''));
      const body    = encodeURIComponent('Hola, adjunto la lista de pacientes del ' + hospital + '.\n\n(Adjunta aquí tu archivo Excel, PDF o Word)');
      document.getElementById('mailto-link').href =
        'mailto:info@redsolidariavenezuela.com?subject=' + subject + '&body=' + body;
      document.getElementById('lista-form').style.display = 'none';
      document.getElementById('upload-ok').style.display = 'block';
    } else {
      btn.textContent = '⚠️ Error al enviar. Intenta de nuevo.';
      btn.disabled = false;
    }
  })
  .catch(() => {
    btn.textContent = '⚠️ Error de conexión. Intenta de nuevo.';
    btn.disabled = false;
  });
}
</script>
