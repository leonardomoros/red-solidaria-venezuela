---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Terremoto Venezuela 2026 — Plataforma de Ayuda y Emergencia',
  description = 'Plataforma de ayuda comunitaria tras el terremoto en Venezuela 2026. Busca personas hospitalizadas, reporta desaparecidos, localiza centros de acopio y dona sangre.'
} = Astro.props;

const canonical = 'https://www.redsolidariavenezuela.com';
const ogImage = `${canonical}/og-image.png`;
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/>

  <!-- Google Tag Manager -->
  <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-NMSS5T4J');</script>
  <!-- End Google Tag Manager -->

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-YD3MKEYVY5" is:inline></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-YD3MKEYVY5');
  </script>
  <!-- End Google tag -->
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

  <!-- Primary -->
  <title>{title}</title>
  <meta name="description" content={description}/>
  <meta name="keywords" content="terremoto venezuela 2026, pacientes hospitalizados venezuela, buscar familiar terremoto, sismo venezuela, centros de acopio venezuela, donar sangre venezuela, desaparecidos terremoto venezuela"/>
  <meta name="author" content="Red Solidaria Venezuela"/>
  <link rel="canonical" href={canonical}/>

  <!-- Open Graph -->
  <meta property="og:type" content="website"/>
  <meta property="og:url" content={canonical}/>
  <meta property="og:title" content={title}/>
  <meta property="og:description" content={description}/>
  <meta property="og:image" content={ogImage}/>
  <meta property="og:image:width" content="1200"/>
  <meta property="og:image:height" content="630"/>
  <meta property="og:locale" content="es_VE"/>
  <meta property="og:site_name" content="Red Solidaria Venezuela"/>

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image"/>
  <meta name="twitter:title" content={title}/>
  <meta name="twitter:description" content={description}/>
  <meta name="twitter:image" content={ogImage}/>

  <!-- Robots -->
  <meta name="robots" content="index, follow"/>

  <!-- Favicon -->
  <link rel="icon" href="/favicon.svg" type="image/svg+xml"/>

  <!-- Sitemap -->
  <link rel="sitemap" href="/sitemap.xml"/>

  <!-- Structured Data -->
  <script type="application/ld+json" is:inline>{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Red Solidaria Venezuela",
    "url": canonical,
    "description": description,
    "inLanguage": "es",
    "potentialAction": {
      "@type": "SearchAction",
      "target": `${canonical}/#hospitales`,
      "query-input": "required name=search_term_string"
    }
  })}</script>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Fraunces:ital,opsz,wght@0,9..144,700;1,9..144,400&display=swap" rel="stylesheet"/>
</head>
<body>
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NMSS5T4J" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->

  <slot/>
</body>
</html>
