---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Terremoto Venezuela 2026 — Busca familiares, refugios y ayuda de emergencia',
  description = 'Busca a tu familiar en hospitales tras el terremoto Venezuela 2026. Avisa que estás bien, reporta desaparecidos, encuentra refugios en La Guaira y dona sangre. Información actualizada en tiempo real.'
} = Astro.props;

const canonical = 'https://www.redsolidariavenezuela.com';
const ogImage = `${canonical}/og-image.png`;

const structuredData = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Red Solidaria Venezuela",
    "url": canonical,
    "description": description,
    "inLanguage": "es",
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": `${canonical}/#hospitales?q={search_term_string}`
      },
      "query-input": "required name=search_term_string"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Red Solidaria Venezuela",
    "url": canonical,
    "logo": `${canonical}/favicon.svg`,
    "description": description,
    "email": "info@redsolidariavenezuela.com",
    "areaServed": { "@type": "Country", "name": "Venezuela" },
    "knowsAbout": [
      "Terremoto Venezuela 2026", "Ayuda humanitaria", "Pacientes hospitalizados",
      "Centros de acopio", "Refugios La Guaira", "Desaparecidos Venezuela",
      "Donación de sangre Venezuela"
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "¿Cómo buscar a un familiar en hospitales tras el terremoto de Venezuela 2026?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Entra a redsolidariavenezuela.com y usa el buscador 'Personas en centros de salud'. Escribe el nombre o cédula de tu familiar para encontrarlo en los registros de hospitales y refugios actualizados en tiempo real."
        }
      },
      {
        "@type": "Question",
        "name": "¿Dónde están los refugios habilitados en La Guaira tras el terremoto?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "La Vicepresidencia Social habilitó 9 refugios en La Guaira: Centro de Adiestramiento Naval, UEN Juan Germán Roscio, Liceo Armando Reverón, Complejo Educativo República de Panamá, Liceo Lorenzo González, UEE La Guaira, UENB 10 de Marzo, CEIS Manuelita Saenz y Universidad Marítima del Caribe. Hay refugios especiales para adultos mayores y niños sin amparo familiar."
        }
      },
      {
        "@type": "Question",
        "name": "¿Cómo avisar a mi familia que estoy bien después del terremoto?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "En redsolidariavenezuela.com entra a la sección 'Estoy Bien' y haz click en 'Avisar que estoy bien'. Publica tu nombre, dónde estás y un mensaje para tu familia. Tu publicación aparece en el carrusel en vivo para que tus seres queridos te encuentren."
        }
      },
      {
        "@type": "Question",
        "name": "¿Cómo reportar a una persona desaparecida por el terremoto de Venezuela?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "En redsolidariavenezuela.com ve a la sección 'Reportar a alguien' y haz click en 'Reportar a alguien'. Ingresa los datos de la persona que buscas: nombre, edad, dónde fue visto por última vez y tu contacto. El reporte es gratuito y aparece en la plataforma para que otros lo vean."
        }
      },
      {
        "@type": "Question",
        "name": "¿Dónde donar sangre en Venezuela tras el terremoto 2026?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "En redsolidariavenezuela.com consulta la sección 'Donar Sangre' con los bancos y jornadas de donación activas en Venezuela. Puedes ir al Hemocentro Chacao, Hospital Domingo Luciani y Hospital Pérez Carreño."
        }
      }
    ]
  }
]);
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/>

  <!-- Google Tag Manager -->
  <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-NMSS5T4J');</script>
  <!-- End Google Tag Manager -->

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-YD3MKEYVY5" is:inline></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-YD3MKEYVY5');
  </script>
  <!-- End Google tag -->
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

  <!-- Primary -->
  <title>{title}</title>
  <meta name="description" content={description}/>
  <meta name="keywords" content="terremoto venezuela 2026, sismo venezuela 2026, buscar familiar terremoto venezuela, personas hospitalizadas venezuela terremoto, refugios la guaira terremoto, estoy bien terremoto venezuela, reportar desaparecido venezuela, buscar persona hospital venezuela, centros de acopio venezuela, donar sangre venezuela, desaparecidos terremoto venezuela, la guaira terremoto, ayuda humanitaria venezuela, buscar paciente hospital venezuela"/>
  <meta name="author" content="Red Solidaria Venezuela"/>
  <link rel="canonical" href={canonical}/>

  <!-- Open Graph -->
  <meta property="og:type" content="website"/>
  <meta property="og:url" content={canonical}/>
  <meta property="og:title" content={title}/>
  <meta property="og:description" content={description}/>
  <meta property="og:image" content={ogImage}/>
  <meta property="og:image:width" content="1200"/>
  <meta property="og:image:height" content="630"/>
  <meta property="og:locale" content="es_VE"/>
  <meta property="og:site_name" content="Red Solidaria Venezuela"/>

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image"/>
  <meta name="twitter:title" content={title}/>
  <meta name="twitter:description" content={description}/>
  <meta name="twitter:image" content={ogImage}/>

  <!-- Robots -->
  <meta name="robots" content="index, follow"/>

  <!-- Favicon -->
  <link rel="icon" href="/favicon.svg" type="image/svg+xml"/>

  <!-- Sitemap -->
  <link rel="sitemap" href="/sitemap.xml"/>

  <!-- Structured Data -->
  <script type="application/ld+json" set:html={structuredData}></script>

  <!-- Preconnects -->
  <link rel="preconnect" href="https://sheets.googleapis.com"/>
</head>
<body>
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NMSS5T4J" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->

  <main>
    <slot/>
  </main>
</body>
</html>
